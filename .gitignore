# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vercel
.claude/
blender-plugin/__pycache__/
public/diorama2.glb
public/tree*.glb
# Block all .glb binaries in public/ by default — already-tracked ones (diorama.glb,
# test-audio-fixture.glb) stay tracked; this only stops new binary scratch files
# (diorama copy.glb, fluid.glb, etc.) from being staged.
public/*.glb
!public/diorama.glb
!public/test-audio-fixture.glb

# Audio raws — encoded outputs in public/audio/ are committed instead.
# Re-encode any time via: bash scripts/encode-audio.sh
src/sfx/

# Local debug helpers + bake backups
aud.mjs
audio-check.mjs
public/diorama.glb.before-bake

# Anvi cognitive catalogues — internal, per-machine
.anvi/

# Local research / planning notes — keep out of version control
artifacts/

# Audio editor — peaks sidecars are auto-regenerated client-side on
# selection (see src/AudioEditorRoute.tsx WaveformCanvas), so tracking
# them adds noise. Per-level uploads still version-control the actual
# WAV/MP3/OGG files; only the .peaks.json caches are ignored.
*.peaks.json
